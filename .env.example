# Arlo credentials
ARLO_USERNAME=your@email.com
ARLO_PASSWORD=yourpassword
ARLO_CAMERA_NAME=Front Door

# 2FA config — "console" prompts interactively (first run only)
# For fully unattended operation, use "imap" and fill in the fields below
ARLO_TFA_SOURCE=console
ARLO_TFA_TYPE=email

# Required only if ARLO_TFA_SOURCE=imap
# ARLO_TFA_HOST=imap.gmail.com
# ARLO_TFA_USER=your@email.com
# ARLO_TFA_PASSWORD=your_imap_app_password
# ARLO_TFA_NICKNAME=Mailbox
# ARLO_TFA_TIMEOUT=3
# ARLO_TFA_TOTAL_TIMEOUT=60
# ARLO_TFA_RETRIES=5
# ARLO_TFA_DELAY=5
# ARLO_TFA_CIPHER_LIST=DEFAULT

# Gemini API key (from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Optional overrides
# CLIPS_DIR=html/clips
# SESSION_DIR=.arlo_session
# DAYS_BACK=1
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
# MIN_CLIP_DURATION_SECONDS=5
# EXCLUDED_OBJ_CATEGORIES=[]
# CLIP_RETENTION_DAYS=7
